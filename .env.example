# Скопируйте в .env и подставьте реальные значения. Файл .env не коммитить.

BOT_TOKEN=
REMNAWAVE_URL=https://panel.example.com
REMNAWAVE_TOKEN=
SUB_DOMAIN=https://sub.example.com

# Telegram ID администраторов через запятую. Эти пользователи получают роль admin
# при старте бота. Без хотя бы одного админа бот не сможет выдавать токены доступа.
ADMIN_TG_IDS=

# Опционально
# DEFAULT_TOKEN_EXPIRE_DAYS=30
# DEFAULT_TOKEN_HWID_LIMIT=3
# DATABASE_PATH=/data/bot_database.db
# LOG_LEVEL=INFO
# LOG_FILE_PATH=
# TZ=Europe/Moscow
# SCHEDULER_CRON_HOUR=12
# SCHEDULER_CRON_MINUTE=0

# === Управление нодами через ansible (опционально) ===
# Хост master-ноды (там лежит репо Ansible и оттуда раскатывается на новые ноды).
# MASTER_SSH_HOST=femboyhooters.kawaiinekos.cfd
# MASTER_SSH_PORT=22
# MASTER_SSH_USER=root
# Путь к приватному ssh-ключу, по которому бот ходит на master-ноду.
# Ключ должен быть смонтирован в контейнер read-only.
# MASTER_SSH_KEY_PATH=/run/secrets/master_ssh_key
# Путь к локальному клону репо Ansible-deploy_new_node-playbook на master-ноде.
# MASTER_ANSIBLE_REPO_PATH=/root/Ansible-deploy_new_node-playbook
