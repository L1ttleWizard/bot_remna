# Скопируйте в .env и подставьте реальные значения. Файл .env не коммитить.

BOT_TOKEN=
REMNAWAVE_URL=https://panel.example.com
REMNAWAVE_TOKEN=
SUB_DOMAIN=https://sub.example.com

# Telegram ID администраторов через запятую. Эти пользователи получают роль admin
# при старте бота. Без хотя бы одного админа бот не сможет выдавать токены доступа.
ADMIN_TG_IDS=

